    print_fibonacci(8);
    print("\n");
    
    show_system_info();
    print("\n");
    
    find_primes(30);
    print("\n");
    
    array_example();
    print("\n");
    
    string_example();
    print("\n");
    
    print("Examples complete!\n");
    
    return 0;
}
